# Database Configuration
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/isl_database

# JWT Secret (Generate a random secret key)
SECRET_KEY=your-secret-key-here-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Server Configuration
HOST=0.0.0.0
PORT=5000
DEBUG=True

# CORS Origins (Frontend URL)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# File Upload
MAX_FILE_SIZE=10485760  # 10MB in bytes
UPLOAD_DIR=uploads

# ML Model Paths
GESTURE_MODEL_PATH=ml_models/gesture_model.pkl
SIGN_DETECTOR_PATH=ml_models/sign_detector.h5
